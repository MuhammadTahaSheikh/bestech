        "jsCode": "const body = $input.first().json.body ?? $input.first().json;\nconst item = { json: body, binary: {} };\n\nif (body.cvBase64) {\n  item.binary.cv = {\n    data: body.cvBase64,\n    mimeType: body.cvMimeType || 'application/octet-stream',\n    fileName: body.cvFileName || 'cv.pdf',\n  };\n}\n\nreturn [item];"
      },
